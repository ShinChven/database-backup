# AWS credentials (or compatible S3 provider)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_DEFAULT_REGION=ap-southeast-1

# Optional: custom endpoint for MinIO / Cloudflare R2 / etc.
# AWS_ENDPOINT_URL=https://your-endpoint.example.com

# Database passwords referenced in config.yaml via ${VAR} syntax
PG_PASSWORD=your_postgres_password
MYSQL_PASSWORD=your_mysql_password
